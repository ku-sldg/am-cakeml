(** val gather_targ_asp : coq_Plc -> coq_TARG_ID -> coq_Term **)

fun gather_targ_asp targPlc targId =
  Coq_asp (ASPC ALL (EXTD (S O)) (Coq_asp_paramsC gather_file_contents_id []
    targPlc targId))

(** val hash_targ_asp : coq_Plc -> coq_TARG_ID -> coq_Term **)

fun hash_targ_asp targPlc targId =
  Coq_asp (ASPC ALL (EXTD (S O)) (Coq_asp_paramsC hash_file_contents_id []
    targPlc targId))

(** val gather_config_1 : coq_Term **)

val gather_config_1 : coq_Term =
  gather_targ_asp cds_config_dir_plc cds_config_1_targ

