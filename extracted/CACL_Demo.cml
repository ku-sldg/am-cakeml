(** val cds_config_dir_plc : coq_Plc **)

val cds_config_dir_plc : coq_Plc =
  "cds_config_dir_plc"

(** val kim_evidence_targ : coq_TARG_ID **)

val kim_evidence_targ : coq_TARG_ID =
  "kim_evidence_targ"

(** val cds_controller_dir_targ : coq_TARG_ID **)

val cds_controller_dir_targ : coq_TARG_ID =
  "cds_controller_dir_targ"

